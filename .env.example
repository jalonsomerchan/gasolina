# Override the default site URL if needed.
ASTRO_SITE=https://example.com

# Use / for root domains or /nombre-repo for subfolder deployments.
ASTRO_BASE=/

# Override the repository link shown in the starter UI.
PUBLIC_REPOSITORY_URL=https://github.com/jalonsomerchan/gasolina

# Public build variable used by the static PWA to call the fuel API.
PUBLIC_GASOLINA_API_KEY=
