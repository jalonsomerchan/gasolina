---
import { fuelTypes, type GasolinaCopy } from '../../data/gasolina';

interface Props {
  copy: GasolinaCopy;
  mode: string;
}

const { copy, mode } = Astro.props;
---

<form class="control-panel" data-search-form>
  <label class="searchbar" for={`gasolina-q-${mode}`}>
    <span class="sr-only">{copy.app.searchLabel}</span>
    <span aria-hidden="true">⌕</span>
    <input id={`gasolina-q-${mode}`} name="q" type="search" list="gasolina-suggestions" placeholder={copy.app.searchPlaceholder} autocomplete="off" />
    <button class="icon-button" type="submit" aria-label={copy.app.searchLabel}>↵</button>
  </label>
  <datalist id="gasolina-suggestions" data-suggestions></datalist>

  <div class="control-grid">
    <label class="select-pill">
      <span>{copy.app.fuel}</span>
      <select name="combustible">
        {fuelTypes.map((fuel) => <option value={fuel.id}>{fuel.label}</option>)}
      </select>
    </label>
    <label class="select-pill">
      <span>{copy.app.radius}</span>
      <select name="radio_km">
        <option value="5">5 km</option>
        <option value="10" selected>10 km</option>
        <option value="25">25 km</option>
      </select>
    </label>
    <label class="quiet-input">
      <span>{copy.app.province}</span>
      <input name="provincia" placeholder={copy.app.anyProvince} />
    </label>
    <label class="quiet-input">
      <span>{copy.app.municipality}</span>
      <input name="municipio" placeholder={copy.app.anyMunicipality} />
    </label>
  </div>
</form>
