---
import AppScript from './AppScript.astro';
import '../styles/gasolina-app.css';
import GasolinaBottomNav from './gasolina/GasolinaBottomNav.astro';
import GasolinaMapPanel from './gasolina/GasolinaMapPanel.astro';
import GasolinaSearchControls from './gasolina/GasolinaSearchControls.astro';
import GasolinaTopBar from './gasolina/GasolinaTopBar.astro';
import HistoryPanel from './gasolina/HistoryPanel.astro';
import PriceRadar from './gasolina/PriceRadar.astro';
import SavingsStrip from './gasolina/SavingsStrip.astro';
import StationSheet from './gasolina/StationSheet.astro';
import { getGasolinaCopy, type GasolinaMode } from '../data/gasolina';
import { defaultLocale, type Locale } from '../config/site';
import { withBasePath } from '../utils/paths';

interface Props {
  locale?: Locale;
  mode?: GasolinaMode;
  title?: string;
  description?: string;
}

const {
  locale = defaultLocale,
  mode = 'home',
  title,
  description,
} = Astro.props;
const copy = getGasolinaCopy(locale);
const apiKey = import.meta.env.PUBLIC_GASOLINA_API_KEY ?? '';
const ipApiBase = import.meta.env.PUBLIC_IP_API_BASE ?? 'http://ip-api.com/json';
const pageTitle = title ?? copy.title;
const pageDescription = description ?? copy.description;
---

<section
  class="gasolina-app"
  data-gasolina-app
  data-mode={mode}
  data-api-base="https://alon.one/api/gasolina2"
  data-api-key={apiKey}
  data-ip-api-base={ipApiBase}
  data-ip-api-lang={locale}
  data-base-path={withBasePath('')}
  data-sw={withBasePath('sw.js')}
  data-empty-label={copy.app.empty}
  data-loading-label={copy.app.loading}
  data-detail-label={copy.app.detail}
  data-zone-label={copy.app.viewZone}
  data-station-saved-label={copy.app.stationSaved}
  data-place-saved-label={copy.app.placeSaved}
  data-location-label={copy.app.location}
  data-location-error-label={copy.app.locationError}
  data-device-location-short={copy.app.deviceLocationShort}
  data-ip-location-label={copy.app.ipLocation}
  data-ip-location-short={copy.app.ipLocationShort}
  data-nearby-title={copy.app.bestNearYou}
  data-demo-notice={copy.app.demoNotice}
>
  <div class="gasolina-phone">
    <GasolinaTopBar copy={copy} />
    <p class="sr-only">{pageTitle}. {pageDescription}</p>
    <GasolinaSearchControls copy={copy} mode={mode} />
    <GasolinaMapPanel copy={copy} />
    <StationSheet copy={copy} />
    <PriceRadar copy={copy} />
    <HistoryPanel copy={copy} />
    <SavingsStrip copy={copy} />
    <GasolinaBottomNav copy={copy} mode={mode} />
  </div>
</section>

<AppScript src={withBasePath('gasolina-app.js')} />