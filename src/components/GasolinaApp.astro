---
import AppScript from './AppScript.astro';
import { gasolinaPages, getGasolinaCopy, type GasolinaMode } from '../data/gasolina';
import { defaultLocale, siteConfig, type Locale } from '../config/site';
import { withBasePath } from '../utils/paths';

interface Props {
  locale?: Locale;
  mode?: GasolinaMode;
  title?: string;
  description?: string;
}

const {
  locale = defaultLocale,
  mode = 'home',
  title,
  description,
} = Astro.props;
const copy = getGasolinaCopy(locale);
const apiKey = import.meta.env.PUBLIC_GASOLINA_API_KEY ?? '';
const currentPage = gasolinaPages.find((page) => page.mode === mode);
const pageTitle = title ?? (currentPage ? copy.pages[currentPage.key] : copy.title);
const pageDescription = description ?? copy.description;
---

<section
  class="gasolina-app"
  data-gasolina-app
  data-mode={mode}
  data-api-base="https://alon.one/api/gasolina2"
  data-api-key={apiKey}
  data-sw={withBasePath('sw.js')}
>
  <div class="hero-panel">
    <p class="eyebrow">{copy.hero.eyebrow}</p>
    <h1>{pageTitle}</h1>
    <p>{pageDescription}</p>
    <div class="hero-actions">
      <button class="button primary" type="button" data-nearby>{copy.hero.primary}</button>
      <a class="button secondary" href={withBasePath('estadisticas/')}>{copy.hero.secondary}</a>
    </div>
  </div>

  <nav class="app-tabs" aria-label="Secciones de gasolina">
    {gasolinaPages.map((page) => (
      <a class={page.mode === mode ? 'is-active' : ''} href={withBasePath(page.path)}>{copy.pages[page.key]}</a>
    ))}
  </nav>

  <form class="search-panel" data-search-form>
    <label for={`gasolina-q-${mode}`}>{copy.app.searchLabel}</label>
    <div class="search-row">
      <input id={`gasolina-q-${mode}`} name="q" type="search" list="gasolina-suggestions" placeholder={copy.app.searchPlaceholder} autocomplete="off" />
      <button class="button primary" type="submit">{copy.app.searchLabel}</button>
    </div>
    <datalist id="gasolina-suggestions" data-suggestions></datalist>
    <div class="filters">
      <label>{copy.app.fuel}<select name="combustible"><option value="gasolina_95">Gasolina 95</option><option value="gasolina_98">Gasolina 98</option><option value="gasoleo_a">Gasóleo A</option></select></label>
      <label>{copy.app.province}<input name="provincia" /></label>
      <label>{copy.app.municipality}<input name="municipio" /></label>
      <label>{copy.app.radius}<input name="radio_km" inputmode="decimal" value="10" /></label>
    </div>
  </form>

  <section class="dashboard-grid" aria-label="Resumen">
    <article class="card accent-card"><span>{copy.app.results}</span><strong data-count>—</strong></article>
    <article class="card"><span>{copy.app.cheapest}</span><strong data-cheap>—</strong></article>
    <article class="card"><span>{copy.app.expensive}</span><strong data-expensive>—</strong></article>
  </section>

  <section class="content-grid">
    <article class="panel large">
      <h2 data-title>{copy.app.results}</h2>
      <p class="state" data-status>{copy.app.loading}</p>
      <div class="cards-list" data-results></div>
      <div class="table-wrap" data-table></div>
    </article>
    <article class="panel map-panel">
      <h2>{copy.app.map}</h2>
      <iframe title={copy.app.map} loading="lazy" data-map></iframe>
    </article>
  </section>

  <section class="content-grid">
    <article class="panel">
      <h2>{copy.app.chart}</h2>
      <div class="chart" data-chart></div>
    </article>
    <article class="panel">
      <h2>{copy.app.utilities}</h2>
      <div class="utility-grid">
        <label>{copy.app.liters}<input name="litros" inputmode="decimal" value="50" /></label>
        <label>{copy.app.priceDifference}<input name="diferencia" inputmode="decimal" value="0.10" /></label>
        <strong data-saving>—</strong>
      </div>
    </article>
  </section>
</section>

<AppScript src={withBasePath('gasolina-app.js')} />
