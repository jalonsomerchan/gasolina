---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import GasolinaApp from '../../components/GasolinaApp.astro';
import { defaultLocale } from '../../config/site';
---

<BaseLayout title="Estadisticas" description="Datos globales, extremos, actualizacion y tendencia de precios." locale={defaultLocale} chrome={false}>
  <Container class="app-screen">
    <GasolinaApp mode="stats" title="Estadisticas" description="Datos globales, extremos, actualizacion y tendencia de precios." locale={defaultLocale} />
  </Container>
</BaseLayout>
