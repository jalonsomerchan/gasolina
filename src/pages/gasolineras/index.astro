---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import GasolinaApp from '../../components/GasolinaApp.astro';
import { defaultLocale } from '../../config/site';
---

<BaseLayout title="Gasolineras" description="Busca gasolineras por municipio, provincia, rótulo o dirección." locale={defaultLocale} chrome={false}>
  <Container class="app-screen">
    <GasolinaApp mode="stations" title="Gasolineras" description="Busca gasolineras por municipio, provincia, rótulo o dirección." locale={defaultLocale} />
  </Container>
</BaseLayout>
