---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import GasolinaApp from '../../components/GasolinaApp.astro';
import { defaultLocale } from '../../config/site';
---

<BaseLayout title="Comparador" description="Compara varias gasolineras y estima el ahorro por repostaje." locale={defaultLocale} chrome={false}>
  <Container class="app-screen">
    <GasolinaApp mode="compare" title="Comparador" description="Compara varias gasolineras y estima el ahorro por repostaje." locale={defaultLocale} />
  </Container>
</BaseLayout>
