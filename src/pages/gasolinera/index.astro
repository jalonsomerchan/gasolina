import Container from '../../components/Container.astro';
import GasolinaApp from '../../components/GasolinaApp.astro';
import { defaultLocale } from '../../config/site';
---

<BaseLayout title="Ficha de gasolinera" description="Detalle, mapa e histórico de una gasolinera concreta." locale={defaultLocale} chrome={false}>
  <Container class="app-screen">
    <GasolinaApp mode="station" title="Ficha de gasolinera" description="Detalle, mapa e histórico de una gasolinera concreta." locale={defaultLocale} />
  </Container>
</BaseLayout>
