---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import GasolinaApp from '../../components/GasolinaApp.astro';
import { defaultLocale, locales, siteConfig, type Locale } from '../../config/site';
import { getGasolinaCopy } from '../../data/gasolina';
import { isLocale } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({
      params: { locale },
    }));
}

const localeParam = Astro.params.locale;
const locale: Locale = isLocale(localeParam) ? localeParam : defaultLocale;
const copy = getGasolinaCopy(locale);
---

<BaseLayout title={siteConfig.name} description={copy.description} locale={locale} chrome={false}>
  <Container class="app-screen">
    <GasolinaApp mode="home" locale={locale} />
    <p class="sr-only">
      <a href={siteConfig.repositoryUrl}>Repository</a>
    </p>
  </Container>
</BaseLayout>
