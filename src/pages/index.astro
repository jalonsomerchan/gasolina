---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import GasolinaApp from '../components/GasolinaApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
---

<BaseLayout title={siteConfig.name} description={siteConfig.description} locale={defaultLocale}>
  <Container class="py-20">
    <GasolinaApp mode="home" locale={defaultLocale} />
  </Container>
</BaseLayout>
