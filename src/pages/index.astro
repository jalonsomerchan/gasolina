---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import GasolinaApp from '../components/GasolinaApp.astro';
import { defaultLocale, siteConfig } from '../config/site';
---

<BaseLayout title={siteConfig.name} description={siteConfig.description} locale={defaultLocale} chrome={false}>
  <Container class="app-screen">
    <GasolinaApp mode="home" locale={defaultLocale} />
    <p class="sr-only">
      <a href={siteConfig.repositoryUrl}>Repositorio del proyecto</a>
    </p>
  </Container>
</BaseLayout>
