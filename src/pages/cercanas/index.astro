import Container from '../../components/Container.astro';
import GasolinaApp from '../../components/GasolinaApp.astro';
import { defaultLocale } from '../../config/site';
---

<BaseLayout title="Gasolineras cercanas" description="Encuentra las gasolineras más próximas a tu ubicación." locale={defaultLocale}>
  <Container class="py-20">
    <GasolinaApp mode="nearby" title="Gasolineras cercanas" description="Encuentra las gasolineras más próximas a tu ubicación." locale={defaultLocale} />
  </Container>
</BaseLayout>
